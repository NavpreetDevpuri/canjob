# Secrets / credentials (never commit)
token.json
*credentials*.json
client_secret*.json
*.pem

# Large precompute intermediate (the full embedding matrix). The small per-job
# semantic_scores.npz under canjob/config/jobs/*/precomputed/ IS committed.
output/
out_docker/

# Generated submission (regenerate with: python rank.py)
submission*.csv

# Python
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/
.venv/
venv/
.appenv/
.DS_Store

# Web app local database (regenerated on first launch)
app/*.db
app/*.db-wal
app/*.db-shm

# Editable presentation source (the PDF in docs/ is the committed deliverable)
docs/*.pptx

# Benchmark dataset download (re-fetched by benchmark/run_benchmark.py; results.json IS committed)
benchmark/data/

# Local notes not part of the submission
CHALLENGE_ANALYSIS.md
